# Template for .env (copy to .env at the repo root and fill in the values).
# .env itself is gitignored; commit ONLY this template.
#
# These credentials are consumed by etl/db/connection.py to open an SSH
# tunnel into the on-prem Postgres and authenticate the psycopg2 session.

# --- SSH tunnel into on-prem server --------------------------------------
SSH_HOST=10.0.18.16
SSH_USER=valeriy
SSH_KEY_PATH=~/.ssh/id_rsa

# --- Postgres (resolved from inside the SSH tunnel) ----------------------
# DB_HOST is the address of Postgres as seen from the on-prem server itself
# (typically the docker bridge → 127.0.0.1 if Postgres binds to localhost,
# or the container service name if running inside docker compose).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=<extract-from-server-/opt/kpi-dashboard/supabase/.env>
